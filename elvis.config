[
    {config, [
        #{
            files => ["src/**/*.erl"],
            rules => [
                %% Keep
                {elvis_style, no_macros, disable},
                {elvis_style, atom_naming_convention, #{
                    regex => "^[a-z](_?[a-zA-Z0-9]+)*(_SUITE)?$"
                }},
                %% Since OTP28
                {elvis_style, prefer_strict_generators, disable},
                %% New in elvis_core 5.x: relax for now
                {elvis_style, prefer_sigils, disable},
                {elvis_style, consistent_ok_error_spec, disable},
                {elvis_style, abc_size, disable},
                {elvis_style, code_complexity, disable},
                {elvis_style, consistent_variable_naming, disable},
                %% Disable rules that are too strict for this codebase
                {elvis_style, no_common_caveats_call, disable},
                {elvis_style, no_init_lists, disable},
                {elvis_style, no_spec_with_records, disable},
                {elvis_style, param_pattern_matching, disable},
                {elvis_style, no_used_ignored_variables, disable},
                {elvis_text_style, max_line_length, #{limit => 120}},
                %% erllama_cache_ram, erllama_inflight, and
                %% erllama_registry are degenerate gen_servers (own
                %% one ETS table; no internal state). erllama_model is
                %% a gen_statem and uses `#data{}` rather than `#state{}`
                %% per gen_statem convention.
                {elvis_style, state_record_and_type, #{
                    ignore => [
                        erllama_cache_ram,
                        erllama_inflight,
                        erllama_registry,
                        erllama_model
                    ]
                }},
                %% erllama_model dispatches to a configurable backend
                %% module via apply/3 (stub or llama). The dynamic call
                %% is intentional; the contract is in
                %% erllama_model_backend.
                {elvis_style, no_invalid_dynamic_calls, #{
                    ignore => [erllama_model]
                }},
                %% throw/1 is used in erllama_cache_kvc as a controlled parse-time
                %% escape, caught at the top level and converted to {error, Reason}.
                {elvis_style, no_throw, #{ignore => [erllama_cache_kvc]}},
                %% Multi-line binary patterns in erllama_cache_kvc make the
                %% header/trailer takers naturally long; the alternative is a
                %% single-line bitstring pattern which is harder to read.
                %% The meta server's handle_call has many short clauses; the
                %% function is naturally long but each clause is small.
                {elvis_style, max_function_length, #{
                    ignore => [erllama_cache_kvc, erllama_cache_meta_srv, erllama_cache_key]
                }},
                {elvis_style, max_function_clause_length, #{ignore => [erllama_cache_kvc]}},
                %% erllama_model is the central gen_statem; it carries
                %% the request lifecycle, the cache integration, and
                %% the streaming/grammar/embed plumbing. Splitting it
                %% would either fragment the state machine across
                %% modules or push too much state through call sites.
                {elvis_style, max_module_length, #{
                    ignore => [erllama_cache_meta_srv, erllama_model]
                }}
            ],
            ruleset => erl_files_strict
        },
        #{
            files => ["include/**/*.hrl"],
            ruleset => hrl_files
        },
        #{
            files => ["rebar.config"],
            ruleset => rebar_config
        }
    ]}
].
