{application, erllama, [
    {description,
        "Native Erlang/OTP wrapper around llama.cpp with OpenAI-compatible API and tiered KV cache"},
    {vsn, "0.1.0"},
    {registered, [erllama_sup, erllama_cache_sup, erllama_cache_meta_srv]},
    {mod, {erllama_app, []}},
    {applications, [
        kernel,
        stdlib,
        sasl,
        crypto,
        iommap
    ]},
    {env, [
        {tiers, [
            #{backend => ram, quota_mb => 4096}
        ]},
        {min_tokens, 512},
        {cold_min_tokens, 512},
        {cold_max_tokens, 30000},
        {continued_interval, 2048},
        {boundary_trim_tokens, 32},
        {boundary_align_tokens, 2048},
        {evict_save_timeout_ms, 30000},
        {session_resume_wait_ms, 500},
        {fingerprint_mode, safe},
        {disk_io, auto}
    ]},
    {modules, []},
    {licenses, ["Apache-2.0"]},
    {links, []},
    %% Hex package manifest. Whitelist what to include and exclude
    %% the parts of vendored llama.cpp that are not needed at build
    %% time (docs, scripts, unused backends already pruned at
    %% vendor time).
    {files, [
        "rebar.config",
        "rebar.lock",
        "do_cmake.sh",
        "do_llama.sh",
        "README.md",
        "AGENTS.md",
        "CLAUDE.md",
        "LICENSE",
        "IOMMAP_PREREQUISITE.md",
        "UPDATE_LLAMA.md",
        "config",
        "src",
        "include",
        "test",
        "c_src/CMakeLists.txt",
        "c_src/erllama_nif.c",
        "c_src/crc32c.c",
        "c_src/crc32c.h",
        "c_src/llama.cpp"
    ]},
    {exclude_files, [
        "c_src/llama.cpp/.git",
        "c_src/llama.cpp/.github",
        "c_src/llama.cpp/.devops",
        "c_src/llama.cpp/.gemini",
        "c_src/llama.cpp/.pi",
        "c_src/llama.cpp/.pre-commit-config.yaml",
        "c_src/llama.cpp/.dockerignore",
        "c_src/llama.cpp/AUTHORS",
        "c_src/llama.cpp/build-xcframework.sh"
    ]}
]}.
