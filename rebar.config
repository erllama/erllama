{minimum_otp_vsn, "28"}.

{erl_opts, [debug_info, warnings_as_errors]}.

{deps, []}.

{pre_hooks, [
    {compile, "make -C c_src"}
]}.

{post_hooks, [
    {clean, "make -C c_src clean"}
]}.

{project_plugins, [
    {rebar3_proper, "~> 0.12"},
    {rebar3_hex, "~> 7.0"},
    {rebar3_ex_doc, "~> 0.2"},
    {rebar3_lint, "~> 5.0"},
    {erlfmt, "~> 1.7"}
]}.

{shell, [
    {apps, [erllama]}
]}.

{relx, [
    {release, {erllama, "0.1.0"}, [erllama, sasl]},
    {dev_mode, true},
    {include_erts, false},
    {sys_config, "./config/sys.config"}
]}.

{profiles, [
    {test, [
        {deps, [
            {proper, "1.4.0"}
        ]},
        {erl_opts, [debug_info, nowarn_export_all]}
    ]},
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]}
]}.

{erlfmt, [
    write,
    {files, [
        "{src,test,include}/**/*.{hrl,erl,app.src,escript}",
        "rebar.config"
    ]}
]}.

{dialyzer, [
    {warnings, [unknown, no_return, error_handling]},
    {plt_apps, top_level_deps}
]}.

{xref_checks, [
    undefined_function_calls,
    locals_not_used,
    deprecated_function_calls
]}.

{hex, [
    {doc, ex_doc}
]}.

{ex_doc, [
    {source_url, <<"https://github.com/benoitc/erllama">>},
    {extras, [
        <<"README.md">>,
        <<"IOMMAP_PREREQUISITE.md">>,
        <<"AGENTS.md">>,
        <<"LICENSE">>
    ]},
    {main, <<"readme">>}
]}.
